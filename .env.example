# TMDB API Key - 用于获取更完整的影视元数据
# 获取方式：访问 https://www.themoviedb.org/settings/api
# 创建账户并申请 API Key（v3 auth）
#
# 使用方法：
# 1. 复制此文件为 .env
# 2. 将你的 API Key 填入下方
# 3. 运行脚本：export TMDB_API_KEY=your_api_key && node scripts/generate_douban_catalog.mjs
#    或者使用：source .env && node scripts/generate_douban_catalog.mjs

TMDB_API_KEY=your_api_key_here

# 猫眼实时票房接口地址 - 默认使用 60s API 的实时猫眼票房接口
# 如需私有部署 60s，可覆盖为自己的实例地址
MAOYAN_BOX_OFFICE_API_URL=https://60s.viki.moe/v2/maoyan/realtime/movie
